        },
        {
            "url": "https://www.facebook.com/groups/polacy.w.anglii",
            "name": "polacy.w.anglii"
        }
    ],
    "group": {
        "url": "https://www.facebook.com/groups/mywpolsce",
        "name": "mywpolsce"
    },
    "n8n": {
        "webhookUrl": "https://n8n-ivorylab.pl/webhook/fb-scraper"
    },
    "proxy": {
        "enabled": false,
        "proxies": [],
        "testOnStartup": true,
        "networkConditions": "4g"
    },
    "safety": {
        "maxPostsPerSession": {
            "min": 5,
            "max": 25
        },
        "intervalMinutes": {
            "min": 10,
            "max": 45
        },
        "activeHours": {
            "enabled": true,
            "strategy": "randomized",
            "startRange": {
                "min": "07:56",
                "max": "08:17"
            },
            "endRange": {
                "min": "17:49",
                "max": "18:21"
            },
            "peakHours": [
                {
                    "start": 9,
                    "end": 11,
                    "activityMultiplier": 1.5
                },
                {
                    "start": 14,
                    "end": 16,
                    "activityMultiplier": 1.3
                },
                {
                    "start": 19,
                    "end": 21,
                    "activityMultiplier": 1.4
                }
            ]
        },
        "workingDays": {
            "enabled": true,
            "days": [
                "monday",
                "tuesday",
                "wednesday",
                "thursday",
                "friday",
                "saturday"
            ],
            "weekendReduction": 0.7
        },
        "stateTracking": {
            "enabled": true,
            "consecutiveKnownLimit": 3,
            "maxPostAgeHours": 24
        },
        "faultTolerance": {
            "maxRetries": 3,
            "retryDelay": 5000,
            "circuitBreakerThreshold": 5,
            "circuitBreakerTimeout": 60000,
            "healthCheckInterval": 30000,
            "maxMemoryUsage": 2048,
            "maxCpuUsage": 80
        },
        "distributed": {
            "maxInstances": 5,
            "healthCheckInterval": 30000,
            "loadBalancingStrategy": "round_robin",
            "instanceTimeout": 120000,
            "sharedStatePath": "./shared-state"
        },
        "humanDelaysConfig": "default"
    }
}