        }
    ],
    "group": {
        "url": "https://www.facebook.com/groups/mywpolsce",
        "name": "mywpolsce"
    },
    "n8n": {
        "webhookUrl": "https://n8n-ivorylab.pl/webhook/fb-scraper"
    },
    "safety": {
        "maxPostsPerSession": {
            "min": 5,
            "max": 25
        },
        "intervalMinutes": {
            "min": 25,
            "max": 75
        },
        "activeHours": {
            "enabled": true,
            "strategy": "randomized",
            "startRange": {
                "min": "06:00",
                "max": "07:00"
            },
            "endRange": {
                "min": "23:00",
                "max": "23:59"
            },
            "peakHours": [
                {
                    "start": 9,
                    "end": 11,
                    "activityMultiplier": 1.3
                },
                {
                    "start": 13,
                    "end": 15,
                    "activityMultiplier": 1.2
                }
            ]
        },
        "workingDays": {
            "enabled": true,
            "days": [
                "monday",
                "tuesday",
                "wednesday",
                "thursday",
                "friday",
                "saturday",
                "sunday"
            ],
            "weekendReduction": 1.0
        },
        "stateTracking": {
            "enabled": true,
            "consecutiveKnownLimit": 3,
            "maxPostAgeHours": 24
        },
        "faultTolerance": {
            "maxRetries": 3,
            "retryDelay": 5000,
            "circuitBreakerThreshold": 5,
            "circuitBreakerTimeout": 60000,
            "healthCheckInterval": 30000,
            "maxMemoryUsage": 2048,
            "maxCpuUsage": 80
        },
        "distributed": {
            "maxInstances": 5,
            "healthCheckInterval": 30000,
            "loadBalancingStrategy": "round_robin",
            "instanceTimeout": 120000,
            "sharedStatePath": "./shared-state"
        },
        "humanDelaysConfig": "default"
    }
}